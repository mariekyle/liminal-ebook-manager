# Copy this file to .env (same folder as docker-compose.yml) and fill in your values.
# .env is gitignored — real paths and secrets never get committed.

# Host path to your ebook library (mounted into the container at /books).
# Required: docker-compose refuses to start without it.
BOOKS_HOST_PATH=/path/to/your/books

# Only needed if you use the auto-deploy webhook (see docs/AUTO_DEPLOY.md).
# WEBHOOK_SECRET=your-webhook-secret
